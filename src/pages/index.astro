---
import Layout from '../layouts/Layout.astro';
import NameEntry from '../components/NameEntry';
---

<Layout title="Inici">
  <div class="flex flex-col items-center justify-center min-h-[80vh] gap-10 text-center">
    <!-- Hero -->
    <div class="space-y-4">
      <div class="text-7xl mb-4">🌏</div>
      <h1 class="text-5xl sm:text-6xl font-extrabold text-white tracking-tight">
        Capitals <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">d'Àsia</span>
      </h1>
      <p class="text-xl text-slate-400 max-w-lg mx-auto">
        Desafia el teu coneixement geogràfic i aprèn les capitals dels 47 països asiàtics en català.
      </p>
      <div class="flex flex-wrap justify-center gap-4 pt-2">
        <div class="flex items-center gap-2 text-slate-400 text-sm">
          <span>🗺️</span> 47 països
        </div>
        <div class="flex items-center gap-2 text-slate-400 text-sm">
          <span>🧠</span> Trucs mnemotècnics
        </div>
        <div class="flex items-center gap-2 text-slate-400 text-sm">
          <span>🏆</span> Rànquing global
        </div>
      </div>
    </div>

    <!-- Name entry component -->
    <NameEntry client:load />
  </div>
</Layout>
